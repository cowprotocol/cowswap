{
  "name": "@cowprotocol/widget-react",
  "version": "3.0.5",
  "description": "CoW Swap Widget Library. Allows you to easily embed a CoW Swap widget on your React application.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cowprotocol/cowswap.git",
    "directory": "libs/widget-react"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "main": "./index.js",
    "types": "./index.d.ts",
    "exports": {
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "require": "./index.cjs"
      }
    }
  },
  "dependencies": {
    "@cowprotocol/events": "workspace:*",
    "@cowprotocol/types": "workspace:*",
    "@cowprotocol/widget-lib": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.1.3",
    "@types/react-dom": "19.1.3",
    "react": "19.1.2",
    "react-dom": "19.1.2"
  },
  "peerDependencies": {
    "react": "19.1.2"
  }
}
