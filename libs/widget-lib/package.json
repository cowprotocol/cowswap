{
  "name": "@cowprotocol/widget-lib",
  "version": "4.2.0",
  "description": "CoW Swap Widget Library. Allows you to easily embed a CoW Swap widget on your website.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cowprotocol/cowswap.git",
    "directory": "libs/widget-lib"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "main": "./index.js",
    "types": "./index.d.ts",
    "exports": {
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "require": "./index.cjs"
      }
    }
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "9.2.1",
    "@cowprotocol/events": "workspace:*",
    "@cowprotocol/iframe-transport": "workspace:*"
  },
  "devDependencies": {
    "csstype": "3.1.3"
  }
}
