{
  "name": "@cowprotocol/currency",
  "version": "1.0.0",
  "description": "CoW Swap re-exports of @uniswap/sdk-core entities",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./index.js",
    "types": "./index.d.ts",
    "exports": {
      ".": {
        "types": "./index.d.ts",
        "import": "./index.mjs",
        "require": "./index.js"
      }
    }
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "8.0.3",
    "jsbi": "^3.1.4"
  }
}
