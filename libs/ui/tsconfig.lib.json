    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../common-utils/tsconfig.lib.json"
    },
    {
      "path": "../common-hooks/tsconfig.lib.json"
    },
    {
      "path": "../common-const/tsconfig.lib.json"
    },
    {
      "path": "../assets/tsconfig.lib.json"
    },
    {
      "path": "../analytics/tsconfig.lib.json"
    }
  ]
}
