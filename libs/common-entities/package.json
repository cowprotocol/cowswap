{
  "name": "@cowprotocol/common-entities",
  "version": "1.0.0",
  "description": "CoW Protocol core domain entities (Currency, Token, Fraction, Price, etc.)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "main": "./index.js",
    "types": "./index.d.ts",
    "exports": {
      ".": {
        "types": "./index.d.ts",
        "import": "./index.mjs",
        "require": "./index.js"
      }
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "7.3.8"
  }
}
