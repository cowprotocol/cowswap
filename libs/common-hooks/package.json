    "@cowprotocol/types": "workspace:*",
    "@lingui/react": "5.5.1",
    "jotai": "2.16.2",
    "launchdarkly-react-client-sdk": "3.0.8",
    "ms.macro": "2.0.0",
    "qs": "6.14.1",
    "react": "19.1.2",
    "react-router": "7.5.2",
    "styled-components": "5.3.11",
    "swr": "2.3.3",
    "timeago.js": "4.0.2",
    "viem": "2.48.8",
    "wagmi": "3.6.9"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/ms.macro": "2.0.0",
    "@types/qs": "6.9.7",
    "@types/react": "19.1.3",
    "@types/styled-components": "5.1.34"
  }
}
