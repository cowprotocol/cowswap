        "import": "./index.mjs",
        "require": "./index.js"
      }
    }
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "9.1.5-pr-897-c3d02aa9.0",
    "@cowprotocol/common-const": "workspace:*",
