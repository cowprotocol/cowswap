{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "ox": ["../../node_modules/ox/_types/index.d.ts"],
      "ox/*": ["../../node_modules/ox/_types/*"]
    }
  },
  "files": ["../../node_modules/@nx/react/typings/cssmodule.d.ts", "../../node_modules/@nx/react/typings/image.d.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx"
  ],
  "include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
  "references": [
    {
      "path": "../wallet-provider/tsconfig.lib.json"
    },
    {
      "path": "../ui/tsconfig.lib.json"
    },
    {
      "path": "../types/tsconfig.lib.json"
    },
    {
      "path": "../iframe-transport/tsconfig.lib.json"
    },
    {
      "path": "../ens/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../common-utils/tsconfig.lib.json"
    },
    {
      "path": "../common-const/tsconfig.lib.json"
    },
    {
      "path": "../assets/tsconfig.lib.json"
    }
  ]
}
