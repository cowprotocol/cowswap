{
  "name": "@cowprotocol/hook-dapp-lib",
  "version": "2.0.9",
  "description": "CoW Swap Hook Dapp Library. Allows you to develop pre/post hooks dapps for CoW Protocol.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cowprotocol/cowswap.git",
    "directory": "libs/hook-dapp-lib"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "main": "./index.js",
    "types": "./index.d.ts",
    "exports": {
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "require": "./index.cjs"
      }
    }
  },
  "dependencies": {
    "@cowprotocol/iframe-transport": "workspace:*"
  }
}
