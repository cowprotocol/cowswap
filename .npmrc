# Deterministic installs
frozen-lockfile=true
# engine-strict=true # disabled because it's already defined in package.json

# Registry control (prevent dependency confusion)
registry=https://registry.npmjs.org/

# Optional (performance/noise)
prefer-offline=true

# Delay newly published versions
minimum-release-age=10080
minimum-release-age-exclude[]=react
minimum-release-age-exclude[]=next
minimum-release-age-exclude[]=typescript
minimum-release-age-exclude[]=@types/*
minimum-release-age-exclude[]=@next/*
minimum-release-age-exclude[]=@cowprotocol/*

# PNPM <= 9
# Enabling this is a double-edged sword, as preinstall/postinstall scripts defined
# in the current project will not be run either. When using strictDepBuilds=true
# and allowBuilds={...} in package.json, builds will not be run either.
# ignore-scripts=true

# Keep newly added dependencies pinned to exact versions.
save-exact=true

# Reject unusual transitive dependency sources/specifiers (e.g. git/tarball)
block-exotic-subdeps=true

# Compares each version to earlier releases of the same package by publish date (not semver).
# Fails install if trust evidence weakens. For example, an older release had npm provenance but the resolved version
# does not.
trust-policy=no-downgrade

# Minutes after publish to skip the trust downgrade check for that version, so recent releases stay protected, while
# older usually transitive deps without provenance (or legacy majors where a newer major added attestations) can install.
trust-policy-ignore-after=10080

# GitHub Packages auth, used only for SDK preview installs (see tools/scripts/install.js).
# pnpm reads `${GITHUB_PACKAGES_TOKEN}` from the environment at install time, so the
# token never lives on disk. Without the env var the placeholder stays literal and is
# harmless — normal installs don't fetch from npm.pkg.github.com.
//npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
