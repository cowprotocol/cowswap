  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": ["./*.ts", "./*.tsx"]
}
