REACT_APP_ENVIRONMENT=local

# Supported values:
# local | development | pr | staging | production

# Enables mock mode (default = true)
MOCK=true

# Enables autoconnect for mock mode (default = true)
AUTOCONNECT=true

# Public IPFS gateway
REACT_APP_IPFS_READ_URI=https://ipfs.io/ipfs

# Sentry
#REACT_APP_EXPLORER_SENTRY_DSN='https://<url>'

# Orderbook API Endpoints
#REACT_APP_ORDER_BOOK_URLS='{"1":"https://YOUR_HOST","100":"https://YOUR_HOST","5":"https://YOUR_HOST"}

# The API key to use for the CoW Protocol Subgraph. {@link https://thegraph.com/studio/apikeys/}
THEGRAPH_API_KEY=

# Block Explorer Override
# Override the default block explorer URL (e.g., Etherscan, Gnosisscan).
# Useful for local development with tools like Otterscan.
# When set, all block explorer links will use this URL instead of the chain's default.
# The URL should not include a trailing slash.
#
# Example for local Otterscan:
#REACT_APP_BLOCK_EXPLORER_URL=http://localhost:8003
