{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/const/*": ["const/*"],
      "@/pages/*": ["pages/*"],
      "@/styles/*": ["styles/*"],
      "@/data/*": ["data/*"],
      "@/util/*": ["util/*"]
    },
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["jest", "node"],
    "composite": true,
    "declaration": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../apps/cow-fi/.next/types/**/*.ts",
    "../../dist/apps/cow-fi/.next/types/**/*.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "jest.config.ts", "**/*.spec.ts", "**/*.test.ts"],
  "references": [
    {
      "path": "../../libs/wallet-provider"
    },
    {
      "path": "../../libs/wallet"
    },
    {
      "path": "../../libs/ui-utils"
    },
    {
      "path": "../../libs/types"
    },
    {
      "path": "../../libs/events"
    },
    {
      "path": "../../libs/core"
    },
    {
      "path": "../../libs/common-utils"
    },
    {
      "path": "../../libs/common-const"
    },
    {
      "path": "../../libs/common-hooks"
    },
    {
      "path": "../../libs/widget-react"
    },
    {
      "path": "../../libs/assets"
    },
    {
      "path": "../../libs/analytics"
    },
    {
      "path": "../../libs/ui"
    }
  ]
}
